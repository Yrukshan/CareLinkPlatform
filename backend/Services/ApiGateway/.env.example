# Backend/.env

# ============================================
# DATABASE CONFIGURATION (Neon DB)
# ============================================
DB_HOST=your_neon_db_host
DB_PORT=5432
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password
DB_NAME=your_db

# ============================================
# JWT CONFIGURATION
# ============================================
JWT_KEY=your_jwt_secret_key_min_32_characters
JWT_ISSUER=careLinkPlatform
JWT_AUDIENCE=careLinkPlatformUsers

# ============================================
# PAYMENT (Stripe)
# ============================================
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key

# ============================================
# AGORA VIDEO
# ============================================
AGORA__AppId=your_agora_app_id
AGORA__AppCertificate=your_agora_certificate

# ============================================
# BASE URL - LOCAL (Uncomment for local)
# ============================================
BASE_SERVICE_URL=https://localhost:5000

# ============================================
# SERVICE URLs - LOCAL (Uncomment for local)
# ============================================
AUTH_SERVICE_URL=http://localhost:5001
PATIENT_SERVICE_URL=http://localhost:5002
DOCTOR_SERVICE_URL=http://localhost:5003
APPOINTMENT_SERVICE_URL=http://localhost:5004
TELEMEDICINE_SERVICE_URL=http://localhost:5007
PAYMENT_SERVICE_URL=http://localhost:5010
NOTIFICATION_SERVICE_URL=http://localhost:5008
SYMPTOM_CHECK_SERVICE_URL=http://localhost:8000

# ============================================
# SWAGGER URLs - LOCAL (Uncomment for local)
# ============================================
AUTH_SWAGGER_URL=http://localhost:5001/swagger/v1/swagger.json
PATIENT_SWAGGER_URL=http://localhost:5002/swagger/v1/swagger.json
DOCTOR_SWAGGER_URL=http://localhost:5003/swagger/v1/swagger.json
APPOINTMENT_SWAGGER_URL=http://localhost:5004/swagger/v1/swagger.json
TELEMEDICINE_SWAGGER_URL=http://localhost:5007/swagger/v1/swagger.json
PAYMENT_SWAGGER_URL=http://localhost:5010/swagger/v1/swagger.json
NOTIFICATION_SWAGGER_URL=http://localhost:5008/swagger/v1/swagger.json
SYMPTOM_CHECK_SWAGGER_URL=http://localhost:8000/openapi.json

# ============================================
# SERVICE URLs - PRODUCTION (Uncomment for Render)
# ============================================
# AUTH_SERVICE_URL=https://carelink-auth-service.onrender.com
# PATIENT_SERVICE_URL=https://carelink-patient-service.onrender.com
# DOCTOR_SERVICE_URL=https://carelink-doctor-service.onrender.com
# APPOINTMENT_SERVICE_URL=https://carelink-appointment-service.onrender.com
# TELEMEDICINE_SERVICE_URL=https://carelink-telemedicine-service.onrender.com
# PAYMENT_SERVICE_URL=https://carelink-payment-service.onrender.com
# NOTIFICATION_SERVICE_URL=https://carelink-notification-service.onrender.com
# SYMPTOM_CHECK_SERVICE_URL=https://carelink-symptom-checker.onrender.com

# ============================================
# SWAGGER URLs - PRODUCTION (Uncomment for Render)
# ============================================
# AUTH_SWAGGER_URL=https://carelink-auth-service.onrender.com/swagger/v1/swagger.json
# PATIENT_SWAGGER_URL=https://carelink-patient-service.onrender.com/swagger/v1/swagger.json
# DOCTOR_SWAGGER_URL=https://carelink-doctor-service.onrender.com/swagger/v1/swagger.json
# APPOINTMENT_SWAGGER_URL=https://carelink-appointment-service.onrender.com/swagger/v1/swagger.json
# TELEMEDICINE_SWAGGER_URL=https://carelink-telemedicine-service.onrender.com/swagger/v1/swagger.json
# PAYMENT_SWAGGER_URL=https://carelink-payment-service.onrender.com/swagger/v1/swagger.json
# NOTIFICATION_SWAGGER_URL=https://carelink-notification-service.onrender.com/swagger/v1/swagger.json
# SYMPTOM_CHECK_SWAGGER_URL=https://carelink-symptom-checker.onrender.com/openapi.json

# ============================================
# ASP.NET ENVIRONMENT
# ============================================
ASPNETCORE_ENVIRONMENT=Development