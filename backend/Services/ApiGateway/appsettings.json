{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "App": {
    "Name": "CareLink Platform API Gateway"
  },
  "AllowedHosts": "*",
  "ServiceSettings": {
    "ServiceName": "ApiGateWayService",
    "DatabaseName": "testDb"
  },
  "Jwt": {
    "Key": "",
    "Issuer": "careLinkPlatform",
    "Audience": "careLinkPlatformUsers"
  },
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/api/v1/Auth/{**catch-all}"
        }
      },
      "patient-route": {
        "ClusterId": "patient-cluster",
        "Match": {
          "Path": "/api/v1/Patients/{**catch-all}"
        }
      },
      "doctor-route": {
        "ClusterId": "doctor-cluster",
        "Match": {
          "Path": "/api/v1/Doctors/{**catch-all}"
        }
      },
      "appointment-route": {
        "ClusterId": "appointment-cluster",
        "Match": {
          "Path": "/api/v1/Appointments/{**catch-all}"
        }
      },
      "telemedicine-route": {
        "ClusterId": "telemedicine-cluster",
        "Match": {
          "Path": "/api/v1/telemedicine/{**catch-all}"
        }
      },
      "payment-route": {
        "ClusterId": "payment-cluster",
        "Match": {
          "Path": "/api/v1/payments/{**catch-all}"
        }
      },
      "notification-route": {
        "ClusterId": "notification-cluster",
        "Match": {
          "Path": "/api/v1/notifications/{**catch-all}"
        }
      },
      "symptom-check-route": {
        "ClusterId": "symptom-check-cluster",
        "Match": {
          "Path": "/api/symptom-checker/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "auth": { "Address": "${AUTH_SERVICE_URL}" }
        }
      },
      "patient-cluster": {
        "Destinations": {
          "patient": { "Address": "${PATIENT_SERVICE_URL}" }
        }
      },
      "doctor-cluster": {
        "Destinations": {
          "doctor": { "Address": "${DOCTOR_SERVICE_URL}" }
        }
      },
      "appointment-cluster": {
        "Destinations": {
          "appointment": { "Address": "${APPOINTMENT_SERVICE_URL}" }
        }
      },
      "telemedicine-cluster": {
        "Destinations": {
          "telemedicine": { "Address": "${TELEMEDICINE_SERVICE_URL}" }
        }
      },
      "payment-cluster": {
        "Destinations": {
          "payment": { "Address": "${PAYMENT_SERVICE_URL}" }
        }
      },
      "notification-cluster": {
        "Destinations": {
          "notification": { "Address": "${NOTIFICATION_SERVICE_URL}" }
        }
      },
      "symptom-check-cluster": {
        "Destinations": {
          "symptom-check": { "Address": "${SYMPTOM_CHECK_SERVICE_URL}" }
        }
      },
      "chatbot-cluster": {
        "Destinations": {
          "chatbot": { "Address": "${CHATBOT_SERVICE_URL}" }
        }
      }
    }
  },
  "SwaggerEndpoints": [
    {
      "Name": "Auth Service",
      "Url": "${AUTH_SWAGGER_URL}"
    },
    {
      "Name": "Patient Service",
      "Url": "${PATIENT_SWAGGER_URL}"
    },
    {
      "Name": "Doctor Service",
      "Url": "${DOCTOR_SWAGGER_URL}"
    },
    {
      "Name": "Appointment Service",
      "Url": "${APPOINTMENT_SWAGGER_URL}"
    },
    {
      "Name": "Telemedicine Service",
      "Url": "${TELEMEDICINE_SWAGGER_URL}"
    },
    {
      "Name": "Payment Service",
      "Url": "${PAYMENT_SWAGGER_URL}"
    },
    {
      "Name": "Notification Service",
      "Url": "${NOTIFICATION_SWAGGER_URL}"
    },
    {
      "Name": "Symptom Check Service",
      "Url": "${SYMPTOM_CHECK_SWAGGER_URL}"
    },
    {
      "Name": "Chatbot Service",
      "Url": "${CHATBOT_SWAGGER_URL}"
    }
  ]
}
